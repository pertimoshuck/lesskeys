<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Lesskeys</title>
    <link>https://pertimoshuck.github.io/lesskeys/appcast.xml</link>
    <description>Lesskeys macOS update feed</description>
    <language>en</language>

    <!--
      Each release adds a new <item>. The <sparkle:minimumPurchaseDate>
      element is read by UpdateEligibilityGate.shouldOffer(...) — items
      released after a Direct customer's update window are skipped.

      ============================================================
      PER-RELEASE PROCEDURE (do NOT tag a version without running this)
      ============================================================
      1. Build + sign + notarize the DMG:
           ./release-dmg.sh <version>           # produces ~/Desktop/Lesskeys-<v>.dmg
      2. Run the appcast helper:
           scripts/sparkle/build_and_sign.sh <version>
         It notarizes, staples, EdDSA-signs the DMG, and prints the
         <item> block (with real length + signature).
      3. Paste that <item> just below this comment AND publish to the repo
         that actually serves the live site — this project repo has NO
         GitHub remote; Pages serves from the separate `pertimoshuck/lesskeys`
         repo. Publish a trimmed copy (strip this comment) with:
           gh api -X PUT repos/pertimoshuck/lesskeys/contents/appcast.xml \
             -f message="Release v<version>: appcast entry" \
             -f sha="$(gh api repos/pertimoshuck/lesskeys/contents/appcast.xml -q .sha)" \
             -f content="$(base64 -i <trimmed-file>)"
         Verify: curl https://pertimoshuck.github.io/lesskeys/appcast.xml
         returns 200 + xmllint clean (Pages deploy takes ~1 min).
      4. Upload the DMG to the release host so the enclosure URL resolves
         BEFORE users check for updates.

      An empty channel simply means "no update available" — current users
      will keep their installed build. They will NOT receive the new
      version automatically until step 3 is committed and step 4 hosted.
      ============================================================

      Template (auto-generated by build_and_sign.sh):

      <item>
        <title>Version 1.8.4</title>
        <pubDate>...</pubDate>
        <sparkle:minimumPurchaseDate>...</sparkle:minimumPurchaseDate>
        <sparkle:shortVersionString>1.8.4</sparkle:shortVersionString>
        <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
        <enclosure
          url="https://pertimoshuck.github.io/lesskeys/Lesskeys-1.8.4.dmg"
          length="..."
          type="application/octet-stream"
          sparkle:edSignature="..."
        />
      </item>
    -->

  </channel>
</rss>
